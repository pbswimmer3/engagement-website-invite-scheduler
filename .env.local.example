# Supabase (same keys as your engagement website)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gmail — use an App Password (NOT your normal password) for each account.
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Create an app password for "Mail"
# 3. Paste the 16-character password below
#
# Each invite template (Praanya, Biswas, Jain) sends from its own Gmail
# account. Set one address + app password per family.
GMAIL_USER_PRAANYA=praanya.email@gmail.com
GMAIL_APP_PASSWORD_PRAANYA=xxxx xxxx xxxx xxxx
GMAIL_USER_BISWAS=biswas.email@gmail.com
GMAIL_APP_PASSWORD_BISWAS=xxxx xxxx xxxx xxxx
GMAIL_USER_JAIN=jain.email@gmail.com
GMAIL_APP_PASSWORD_JAIN=xxxx xxxx xxxx xxxx

# Optional fallback used only if a group-specific Gmail pair above is not set.
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Your engagement website URL (for the RSVP link in emails)
WEBSITE_URL=https://your-engagement-site.vercel.app

# Per-invite-group website passwords. Each invite template (Praanya, Biswas,
# Jain) shows its own password at the bottom of the email so each family can
# have a distinct password on the engagement website.
WEBSITE_PASSWORD_PRAANYA=PraanyaForever2026
WEBSITE_PASSWORD_BISWAS=BiswasForever2026
WEBSITE_PASSWORD_JAIN=JainForever2026

# Optional fallback used if a group-specific password above is not set.
WEBSITE_PASSWORD=Forever2026
